# Required: Telegram Bot API token (obtain from @BotFather)
TELEGRAM_TOKEN=your-telegram-bot-token-here

# Required: Google Gemini API key (obtain from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: Session idle timeout in minutes before context is cleared (default: 60)
SESSION_TIMEOUT_MINUTES=60

# Optional: Maximum image size in bytes to accept (default: 10 MB)
MAX_IMAGE_SIZE_BYTES=10485760

# Optional: Gemini model name — externalised so it can be updated without a code change
# when the preview model graduates to GA
GEMINI_MODEL=gemini-3.1-flash-image-preview
